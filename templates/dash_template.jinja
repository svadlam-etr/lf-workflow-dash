<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }}</title>
  <style>
    body {
      background: #1f1f1f;
      color: #e8e8e8;
      font-family: Arial, Helvetica, sans-serif;
      margin: 0;
      padding: 18px;
    }

    h1 {
      margin: 0 0 14px 0;
      font-size: 24px;
      color: #f3f3f3;
    }

    .table-wrap {
      max-width: 1400px;
      margin: 0 auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: auto;
      background: #2a2a2a;
    }

    th, td {
      padding: 6px 10px;
      font-size: 13px;
      line-height: 1.2;
      vertical-align: middle;
      border-bottom: 1px solid #444;
      text-align: left;
    }

    th {
      background: #202020;
      color: #f2f2f2;
      font-weight: 700;
      position: sticky;
      top: 0;
      z-index: 1;
    }

    tr:nth-child(even) td {
      background: #303030;
    }

    a {
      color: #8fd3ff;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    .repo-col {
      width: 28%;
      font-weight: 600;
      word-break: break-word;
    }

    .status-col {
      width: 22%;
      white-space: nowrap;
    }

    .workflow-block {
      margin: 0;
      padding: 0;
    }

    .workflow-name {
      display: block;
      color: #8fd3ff;
      font-weight: 600;
      margin-bottom: 2px;
    }

    .workflow-status {
      display: inline-block;
      font-weight: 700;
      margin-right: 10px;
    }

    .success {
      color: #8ee26b;
    }

    .failure,
    .failed,
    .error {
      color: #ff7b7b;
    }

    .cancelled {
      color: #ffbf66;
    }

    .stale {
      color: #ffbf66;
      font-style: italic;
      margin-right: 6px;
    }

    .time {
      color: #d9d9d9;
      white-space: nowrap;
    }

    .footer {
      max-width: 1400px;
      margin: 14px auto 0 auto;
      font-size: 12px;
      color: #cfcfcf;
    }

    .footer a {
      color: #8fd3ff;
    }
  </style>
</head>
<body>
  <div class="table-wrap">
    <h1>{{ page_title }}</h1>

    <table>
      <thead>
        <tr>
          <th class="repo-col">Repository</th>
          {% if contains_smoke %}<th>Nightly Test</th>{% endif %}
          {% if contains_bench %}<th>Nightly Benchmarks</th>{% endif %}
          {% if contains_docs %}<th>Build Docs</th>{% endif %}
          {% if contains_live %}<th>Live Build</th>{% endif %}
          {% if contains_other %}<th class="status-col">Workflow-Status</th>{% endif %}
        </tr>
      </thead>
      <tbody>
        {% for project in all_projects %}
        <tr>
          <td class="repo-col">
            <a href="https://github.com/{{ project.owner }}/{{ project.repo }}" target="_blank">{{ project.repo }}</a>
          </td>

          {% if contains_smoke %}
          <td>
            {% if project.smoke_test.is_stale %}<span class="stale">stale</span>{% endif %}
            <span class="workflow-status {{ project.smoke_test.workflow_status|lower }}">{{ project.smoke_test.workflow_status }}</span>
            <a class="time" href="{{ project.smoke_test.url }}" target="_blank">{{ project.smoke_test.conclusion_time }}</a>
          </td>
          {% endif %}

          {% if contains_bench %}
          <td>
            {% if project.benchmarks.is_stale %}<span class="stale">stale</span>{% endif %}
            <span class="workflow-status {{ project.benchmarks.workflow_status|lower }}">{{ project.benchmarks.workflow_status }}</span>
            <a class="time" href="{{ project.benchmarks.url }}" target="_blank">{{ project.benchmarks.conclusion_time }}</a>
          </td>
          {% endif %}

          {% if contains_docs %}
          <td>
            <span class="workflow-status {{ project.build_docs.workflow_status|lower }}">{{ project.build_docs.workflow_status }}</span>
            <a class="time" href="{{ project.build_docs.url }}" target="_blank">{{ project.build_docs.conclusion_time }}</a>
          </td>
          {% endif %}

          {% if contains_live %}
          <td>
            {% if project.live_build.is_stale %}<span class="stale">stale</span>{% endif %}
            <span class="workflow-status {{ project.live_build.workflow_status|lower }}">{{ project.live_build.workflow_status }}</span>
            <a class="time" href="{{ project.live_build.url }}" target="_blank">{{ project.live_build.conclusion_time }}</a>
          </td>
          {% endif %}

          {% if contains_other %}
          <td class="status-col">
            {% for workflow in project.other_workflows %}
              <div class="workflow-block">
                <span class="workflow-name">{{ workflow.friendly_name }}</span>
                <span class="workflow-status {{ workflow.workflow_status|lower }}">{{ workflow.workflow_status }}</span>
                <a class="time" href="{{ workflow.url }}" target="_blank">{{ workflow.conclusion_time_one_line }}</a>
              </div>
            {% endfor %}
          </td>
          {% endif %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="footer">
    Last Updated {{ last_updated }} |
    <a href="{{ dash_repo }}">dashboard repo</a>
    {% for link in extra_links %}
      | <a href="{{ link.url }}">{{ link.text }}</a>
    {% endfor %}
  </div>
</body>
</html>
